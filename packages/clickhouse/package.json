{
  "name": "@conquext/clickhouse",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src/migrations"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@conquext/core": "workspace:*"
  },
  "peerDependencies": {
    "@clickhouse/client": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@clickhouse/client": {
      "optional": true
    }
  }
}
